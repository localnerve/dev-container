# Copy to .env and fill in for your machine.

# Path to your projects directory, mounted at /workspace in the container.
PROJECTS_PATH=/Users/youruser/projects

# macOS ssh-agent socket (Docker Desktop convention).
SSH_AUTH_SOCK=/run/host-services/ssh-auth.sock

# The REAL Docker Desktop socket path — NOT /var/run/docker.sock, which is a
# symlink on macOS. Confirm with:
#   ls -la /var/run/docker.sock
# It should point to something like ~/.docker/run/docker.sock — use that
# resolved path here.
DOCKER_SOCK=/Users/youruser/.docker/run/docker.sock

# GID to join inside the container for Docker socket access. On Docker
# Desktop for Mac the socket is owned root:root as seen from inside any
# container (regardless of its host-side apparent ownership), so 0 is the
# correct default. Verify with:
#   docker exec -it dev-env ls -la /var/run/docker.sock
DOCKER_GID=0

# Path to your Caddyfile
CADDY_CONF_PATH=/path/to/caddy/conf

# Duckdns token for Caddy-duckdns custom challenge plugin for managed local SSL
DUCKDNS_TOKEN=Your-DuckDns-Token

# Openbao dev mode root token
BAO_TOKEN=Your-Dev-Root-Bao-Token
